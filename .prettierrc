{
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 180,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "web/src/index.css",
  "tailwindFunctions": ["cn", "cva", "tw", "mergeStyles"]
}
